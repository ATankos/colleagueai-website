{
  "name": "colleagueai-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/generate-agent-pages.mjs && node scripts/generate-locale-pages.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:prod": "playwright test --config=playwright.prod.config.js",
    "visual": "playwright test visual.spec.js --project=chromium",
    "visual:update": "playwright test visual.spec.js --project=chromium --update-snapshots",
    "a11y": "playwright test a11y.spec.js --project=chromium",
    "lhci": "npm run build && node ./scripts/run-lhci.mjs",
    "lhci:report": "start .lighthouseci",
    "diacritics": "playwright test diacritics.spec.js",
    "edge-cases": "playwright test edge-cases.spec.js --project=chromium",
    "check": "npm run lint && npm run test:run",
    "check:e2e": "npm run lint && npm run test:run && playwright test",
    "check:full": "npm run lint && npm run test:run && playwright test && npm run lhci",
    "smoke:prod": "node scripts/smoke-production.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@sentry/react": "^10.57.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "aws4fetch": "^1.0.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.2.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.8",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^12.6.1",
    "serve": "^14.2.6",
    "vite": "^8.0.16",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "tmp": "^0.2.6",
    "uuid": "^11.1.1"
  }
}
