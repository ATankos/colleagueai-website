# Template for environment variables — committed to git as documentation.
# Copy this file to .env.local and fill in real values.
# Also add all of these to Vercel → Project → Settings → Environment Variables.

# Anthropic (AI demo agent)
ANTHROPIC_API_KEY=sk-ant-...
DEMO_MAX_CALLS=500

# Sentry error tracking DSN — public-by-design (it only allows sending errors)
VITE_SENTRY_DSN=

# Stripe (gated delivery backend)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Vercel KV or Upstash Redis (entitlement store — free tier is fine)
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# Cloudflare R2 (artifact storage — free tier: 10 GB)
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=colleague-ai-artifacts
R2_PUBLIC_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# Optional
SIGNED_URL_TTL_SECONDS=900

# Download token signing secret
DOWNLOAD_TOKEN_SECRET=replace-with-random-32-byte-secret
